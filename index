@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}

/* \u2500\u2500 Toast \u2500\u2500 */
@keyframes toastIn{from{opacity:0;transform:translateY(16px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes toastOut{from{opacity:1;transform:translateY(0)}to{opacity:0;transform:translateY(8px)}}
.toast-wrap{position:fixed;left:0;right:0;bottom:calc(env(safe-area-inset-bottom,0) + 20px);z-index:9999;display:flex;flex-direction:column;align-items:center;gap:8px;pointer-events:none;padding:0 16px}
.toast{max-width:400px;width:auto;pointer-events:auto;display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;font-size:14px;font-weight:500;line-height:1.4;box-shadow:0 6px 24px rgba(0,0,0,.16),0 2px 6px rgba(0,0,0,.08);animation:toastIn .28s cubic-bezier(.2,.9,.3,1.2);backdrop-filter:blur(8px)}
.toast-ok{background:#2E5D45;color:#fff}
.toast-err{background:#C0574E;color:#fff}
.toast-info{background:#3A4A5A;color:#fff}
.toast-icon{flex-shrink:0;width:18px;height:18px;display:flex;align-items:center;justify-content:center}


/* \u2500\u2500 Light (default) \u2500\u2500 */
:root{
  --bg:#F6F4EF;
  --surface:#FFFFFF;
  --surface2:#F9F7F2;
  --surface3:#F1EEE7;
  --sep:#DDD8CD;
  --border:#E5E1D8;
  --border2:#DDD8CD;
  --overlay:rgba(42,37,32,.42);
  --text:#2A2520;
  --text2:#78706A;
  --text3:#A8A099;
  --accent:#C9A24E;
  --accent-light:#D9B46A;
  --accent-dark:#A8842E;
  --accent-bg:rgba(201,162,78,.08);
  --accent-border:rgba(201,162,78,.22);
  --btn-bg:#C9A24E;
  --btn-text:#FFFFFF;
  --green:#3A7057;
  --green-light:#667452;
  --green-bg:rgba(77,134,107,.09);
  --green-mid:#2D5E47;
  --red:#C0574E;
  --red-bg:rgba(192,87,78,.09);
  --blue:#3E6A8F;
  --blue-bg:rgba(92,127,163,.09);
  --amber:#D99A3E;
  --amber-bg:rgba(217,154,62,.1);
  --purple:#B385CC;
  --purple-bg:rgba(179,133,204,.09);
  --shadow-xs:0 1px 3px rgba(31,41,55,.06),0 1px 2px rgba(31,41,55,.04);
  --shadow-sm:0 2px 8px rgba(31,41,55,.08),0 1px 3px rgba(31,41,55,.05);
  --shadow-md:0 8px 24px rgba(31,41,55,.1),0 2px 8px rgba(31,41,55,.06);
  --shadow-lg:0 20px 48px rgba(31,41,55,.14),0 4px 12px rgba(31,41,55,.08);
  --r-xs:4px;--r-sm:8px;--r-md:11px;--r-lg:14px;--r-xl:18px;
}

/* \u2500\u2500 Dark \u2500\u2500 */
[data-theme="dark"]{
  --bg:#111315;
  --surface:#171A1F;
  --surface2:#1D2127;
  --surface3:#242933;
  --sep:#353B47;
  --border:#2E3440;
  --border2:#353B47;
  --overlay:rgba(0,0,0,.65);
  --text:#F5F5F5;
  --text2:#B0B7C3;
  --text3:#6B7280;
  --accent:#D6A85F;
  --accent-light:#E4BB7A;
  --accent-dark:#B88A40;
  --accent-bg:rgba(214,168,95,.1);
  --accent-border:rgba(214,168,95,.25);
  --btn-bg:#D6A85F;
  --btn-text:#111315;
  --green:#7EC4A4;
  --green-light:#7A9362;
  --green-bg:rgba(79,137,111,.1);
  --green-mid:#5EA88A;
  --red:#D97066;
  --red-bg:rgba(217,112,102,.12);
  --blue:#8DC0E8;
  --blue-bg:rgba(109,147,199,.1);
  --amber:#E5A94D;
  --amber-bg:rgba(229,169,77,.12);
  --purple:#C9A0DF;
  --purple-bg:rgba(201,160,223,.12);
  --shadow-xs:0 1px 3px rgba(0,0,0,.35);
  --shadow-sm:0 2px 8px rgba(0,0,0,.45),0 0 0 1px rgba(255,255,255,.04);
  --shadow-md:0 8px 24px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.05);
  --shadow-lg:0 20px 48px rgba(0,0,0,.75),0 0 0 1px rgba(255,255,255,.06);
}
[data-theme="dark"]{color:var(--text);background:var(--bg)}
[data-theme="dark"] .topbar{background:rgba(17,19,21,.96)!important;backdrop-filter:blur(24px)}
[data-theme="dark"] .hm-menu{background:rgba(17,19,21,.98)!important;backdrop-filter:blur(24px)}
[data-theme="dark"] .bottom-nav{background:rgba(17,19,21,.97)!important;backdrop-filter:blur(24px)}
[data-theme="dark"] .modal{background:var(--surface)!important}
[data-theme="dark"] .oz-lbl{color:var(--text2)}
[data-theme="dark"] .kasa-lbl{color:var(--text2)}
[data-theme="dark"] .oz-hd{color:var(--text2)}
[data-theme="dark"] .sec-head{color:var(--text2)}
[data-theme="dark"] .settings-sec-head{color:var(--text2)}
[data-theme="dark"] .sec-total{color:var(--text2)}
[data-theme="dark"] .dd{color:var(--text2)}
[data-theme="dark"] .gt-lbl{color:var(--text2)}
[data-theme="dark"] .sl{color:var(--text2)}
[data-theme="dark"] .tab:not(.active){color:var(--text2)}
[data-theme="dark"] .s-tab:not(.active){color:var(--text2)}
